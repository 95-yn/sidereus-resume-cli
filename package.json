{
  "name": "sidereus-resume-cli",
  "version": "1.0.0",
  "description": "AI-powered PDF resume parsing and JD matching CLI",
  "license": "MIT",
  "keywords": [
    "resume",
    "cli",
    "pdf",
    "deepseek",
    "openai",
    "typescript"
  ],
  "type": "module",
  "bin": {
    "resume-cli": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "check": "npm run lint && npm run typecheck && npm test && npm run build",
    "demo:pdf": "node scripts/create-demo-resume.mjs",
    "demo": "npm run build && npm run demo:pdf && node dist/cli.js parse examples/resume.pdf && node dist/cli.js extract examples/resume.pdf --mock && node dist/cli.js score examples/resume.pdf --jd examples/jd.txt --mock",
    "prepare": "npm run build",
    "prepack": "npm run check"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "openai": "^6.48.0",
    "ora": "^9.4.1",
    "pdf-parse": "^2.4.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@types/pdfkit": "^0.17.5",
    "eslint": "^10.7.0",
    "pdfkit": "^0.19.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  }
}
